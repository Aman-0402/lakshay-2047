{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/auth/[...nextauth]",
      "regex": "^/api/auth/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPnextauth": "nxtPnextauth"
      },
      "namedRegex": "^/api/auth/(?<nxtPnextauth>.+?)(?:/)?$"
    },
    {
      "page": "/api/bookings/[id]",
      "regex": "^/api/bookings/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/bookings/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/labs/[slug]",
      "regex": "^/api/labs/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/api/labs/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/teams/[id]/join",
      "regex": "^/api/teams/([^/]+?)/join(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/teams/(?<nxtPid>[^/]+?)/join(?:/)?$"
    },
    {
      "page": "/book/[labSlug]",
      "regex": "^/book/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPlabSlug": "nxtPlabSlug"
      },
      "namedRegex": "^/book/(?<nxtPlabSlug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/labs/[slug]",
      "regex": "^/labs/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/labs/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/teams/[id]",
      "regex": "^/teams/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/teams/(?<nxtPid>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/about",
      "regex": "^/about(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/about(?:/)?$"
    },
    {
      "page": "/dashboard",
      "regex": "^/dashboard(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard(?:/)?$"
    },
    {
      "page": "/events",
      "regex": "^/events(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/events(?:/)?$"
    },
    {
      "page": "/insights",
      "regex": "^/insights(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/insights(?:/)?$"
    },
    {
      "page": "/labs",
      "regex": "^/labs(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/labs(?:/)?$"
    },
    {
      "page": "/partners",
      "regex": "^/partners(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/partners(?:/)?$"
    },
    {
      "page": "/teams",
      "regex": "^/teams(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/teams(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}